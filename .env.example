# =============================================================================
# Mi Tiendita — variables de entorno (copia este archivo a .env)
# =============================================================================
#   cp .env.example .env
#
# Sin .env o con valores de ejemplo, la app arranca en MODO DEMO (datos mock).
# Para forzar demo: VITE_DEMO_MODE=true
# Para forzar producción local: VITE_DEMO_MODE=false (requiere Firebase válido)
# =============================================================================

# --- Firebase (públicas — seguras en el frontend) ---
# Consola: https://console.firebase.google.com → Configuración → Tus apps → Web
VITE_FIREBASE_API_KEY=tu_api_key
VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu-proyecto
VITE_FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# --- Culqi (solo llave PÚBLICA en el frontend) ---
# Panel Culqi → Desarrollo → Llaves de prueba
VITE_CULQI_PUBLIC_KEY=pk_test_xxxxxxxx

# --- Cloud Functions (después de firebase deploy --only functions) ---
# Formato: https://us-central1-TU_PROYECTO.cloudfunctions.net
VITE_FUNCTIONS_URL=https://us-central1-tu-proyecto.cloudfunctions.net

# --- Modo demo (opcional) ---
# true = siempre demo | false = siempre Firebase | vacío = auto-detecta
# VITE_DEMO_MODE=
